        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1Role"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "role",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "etag",
            "description": "Optional. The etag for optimistic concurrency control.",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "Roles"
        ]
      },
      "patch": {
        "summary": "Updates a role.",
        "operationId": "Roles_UpdateRole",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1Role"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "role",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "role",
            "description": "Required. The role with updated fields.",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "displayName": {
                  "type": "string",
                  "description": "Required. A human-readable name for the role."
                },
                "description": {
                  "type": "string",
                  "description": "Optional. A longer description of the role's purpose."
                },
                "permissions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Output only. The permissions granted by this role, resolved from the\nrole_permissions join table.",
                  "readOnly": true
                },
                "system": {
                  "type": "boolean",
                  "description": "Output only. Whether this is a system-defined role (owner, admin, editor,\nviewer). System roles cannot be deleted or have their permissions changed.",
                  "readOnly": true
                },
                "createTime": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Output only. Timestamp when the role was created.",
                  "readOnly": true
                },
                "updateTime": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Output only. Timestamp when the role was last modified.",
                  "readOnly": true
                },
                "deleteTime": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Output only. Timestamp when the role was soft-deleted.",
                  "readOnly": true
                },
                "purgeTime": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Output only. Timestamp when the role will be permanently purged.",
                  "readOnly": true
                },
                "etag": {
                  "type": "string",
                  "description": "Output only. A checksum computed by the server based on the current value\nof the Role resource.",
                  "readOnly": true
                },
                "annotations": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "description": "Optional. Free-form annotations for the role."
                }
              },
              "title": "Required. The role with updated fields.",
              "required": [
                "displayName"
              ]
            }
          }
        ],
        "tags": [
          "Roles"
        ]
      }
    },
