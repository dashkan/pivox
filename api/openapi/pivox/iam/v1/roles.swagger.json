  "paths": {
    "/v1/organizations/{organization}/roles": {
      "get": {
        "summary": "Lists roles in an organization.",
        "operationId": "Roles_ListRoles",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListRolesResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "pageSize",
            "description": "Optional. Maximum number of roles to return.",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pageToken",
            "description": "Optional. Page token from a previous ListRoles call.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "description": "Optional. An AIP-160 filter expression.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "orderBy",
            "description": "Optional. Sort order (e.g. \"display_name\", \"create_time desc\").",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "showDeleted",
            "description": "Optional. Whether to include soft-deleted roles.",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "Roles"
        ]
      },
      "post": {
        "summary": "Creates a new custom role.",
        "operationId": "Roles_CreateRole",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1Role"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "role",
            "description": "Required. The role to create.",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1Role"
            }
          },
          {
            "name": "roleId",
            "description": "Optional. The server-generated role ID. If not provided, the server\nwill generate one.",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "Roles"
        ]
      }
    },
    "/v1/organizations/{organization}/roles/{role}": {
      "get": {
        "summary": "Gets a role by resource name.",
