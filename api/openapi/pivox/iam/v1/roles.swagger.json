            "type": "string"
          },
          {
            "name": "role",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "Roles"
        ]
      },
      "delete": {
        "summary": "Soft-deletes a role. System roles cannot be deleted.",
