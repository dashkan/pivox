{
  "name": "pivox",
  "version": "1.0.0",
  "private": true,
  "description": "Pivox Observability Platform",
  "scripts": {
    "dev": "concurrently -n prims,ui,feat,web,server,nginx,ngrok -c cyan,cyan,cyan,blue,green,yellow,magenta \"pnpm web:build:primitives -- --watch\" \"pnpm web:build:ui -- --watch\" \"pnpm web:build:features -- --watch\" \"pnpm web:start\" \"pnpm server:run\" \"pnpm proxy:nginx\" \"pnpm proxy:ngrok\"",
    "server:build": "go build -o bin/server ./cmd/server",
    "server:run": "go run ./cmd/server",
    "server:test": "go test ./...",
    "server:tidy": "go mod tidy && cd tools && go mod tidy",
    "server:lint": "go tool -modfile=./tools/go.mod golangci-lint run ./...",
    "server:lint:fix": "go tool -modfile=./tools/go.mod golangci-lint run --fix ./...",
    "server:fmt": "gofmt -w .",
    "proto:lint": "go tool -modfile=./tools/go.mod buf lint",
    "proto:format": "go tool -modfile=./tools/go.mod buf format -w",
    "proto:breaking": "go tool -modfile=./tools/go.mod buf breaking --against '.git#branch=main'",
    "proto:generate": "go tool -modfile=./tools/go.mod buf generate",
    "proto:api-lint": "go tool -modfile=./tools/go.mod api-linter --proto-path=api/proto --config=api/proto/api-linter.yaml --set-exit-status api/proto/pivox/**/**/*.proto",
    "db:migrate:up": "migrate -path internal/db/migrations -database \"${DATABASE_URL:-postgres://localhost:5432/pivox?sslmode=disable}\" up",
    "db:migrate:down": "migrate -path internal/db/migrations -database \"${DATABASE_URL:-postgres://localhost:5432/pivox?sslmode=disable}\" down 1",
    "db:migrate:create": "migrate create -ext sql -dir internal/db/migrations -seq",
    "db:migrate:force": "migrate -path internal/db/migrations -database \"${DATABASE_URL:-postgres://localhost:5432/pivox?sslmode=disable}\" force",
    "db:seed": "psql \"${DATABASE_URL:-postgres://localhost:5432/pivox?sslmode=disable}\" -f scripts/seed.sql",
    "db:clear": "psql \"${DATABASE_URL:-postgres://localhost:5432/pivox?sslmode=disable}\" -c \"DO \\$\\$ DECLARE r RECORD; BEGIN FOR r IN (SELECT tablename FROM pg_tables WHERE schemaname = 'public' AND tablename != 'schema_migrations') LOOP EXECUTE 'TRUNCATE TABLE ' || quote_ident(r.tablename) || ' CASCADE'; END LOOP; END \\$\\$;\"",
    "db:drop": "psql \"postgres://localhost:5432?sslmode=disable\" -c \"DROP DATABASE IF EXISTS ${DATABASE_NAME:-pivox}\"",
    "db:create": "psql \"postgres://localhost:5432?sslmode=disable\" -c \"CREATE DATABASE ${DATABASE_NAME:-pivox}\"",
    "web": "pnpm --dir web",
    "web:start": "pnpm web --filter @pivox/start dev",
    "web:build": "pnpm --dir web run build",
    "web:build:primitives": "pnpm web --filter @pivox/primitives build",
    "web:build:features": "pnpm web --filter @pivox/features build",
    "web:build:ui": "pnpm web --filter @pivox/ui build",
    "web:clean": "pnpm --dir web run clean",
    "firebase:emulators": "firebase emulators:start --import=.firebase-data --export-on-exit=.firebase-data",
    "firebase:deploy": "firebase deploy",
    "firebase:deploy:funcs": "firebase deploy --only functions",
    "firebase:deploy:hosting": "firebase deploy --only hosting",
    "proxy:nginx": "nginx -c $PWD/configs/nginx.conf -e stderr",
    "proxy:nginx:stop": "nginx -c $PWD/configs/nginx.conf -s stop",
    "proxy:ngrok": "ngrok start --config configs/ngrok.yml --all",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
