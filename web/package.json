{
  "name": "pivox",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "clean": "pnpm --filter \"./packages/**\" run clean",
    "build": "pnpm --filter \"./packages/**\" run build",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "test:eslint": "pnpm -r --filter \"./packages/**\" --filter \"./apps/**\" run test:eslint",
    "test:types": "pnpm -r --filter \"./packages/**\" --filter \"./apps/**\" run test:types",
    "dev": "concurrently -n prims,image-editor,ui,feat,web,server -c cyan,cyan,cyan,cyan,blue,red,green \"pnpm web:build:primitives -- --watch\" \"pnpm web:build:image-editor -- --watch\" \"pnpm web:build:ui -- --watch\" \"pnpm web:build:features -- --watch\" \"pnpm web:start\" \"pnpm server:run\"",
    "dev:electron": "concurrently -n prims,image-editor,ui,feat,web,electron,server -c cyan,cyan,cyan,cyan,blue,red,green \"pnpm web:build:primitives -- --watch\" \"pnpm web:build:image-editor -- --watch\" \"pnpm web:build:ui -- --watch\" \"pnpm web:build:features -- --watch\" \"pnpm web:start\" \"pnpm electron:start\"",
    "web:build": "pnpm run build",
    "web:build:primitives": "pnpm --filter @pivox/primitives run build",
    "web:build:image-editor": "pnpm --filter @pivox/image-editor run build",
    "web:build:features": "pnpm --filter @pivox/features build",
    "web:build:ui": "pnpm --filter @pivox/ui build",
    "web:clean": "pnpm clean",
    "web:start": "pnpm --filter @pivox/start dev"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.4.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "premove": "^4.0.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "electron",
      "electron-winstaller",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
